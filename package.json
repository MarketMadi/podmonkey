{
  "name": "podmonkey",
  "version": "0.3.1",
  "description": "Paste Kubernetes YAML. Compare cloud bills across AWS, GCP, Azure, and Hetzner.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MarketMadi/podmonkey.git"
  },
  "homepage": "https://marketmadi.github.io/podmonkey/",
  "bugs": {
    "url": "https://github.com/MarketMadi/podmonkey/issues"
  },
  "keywords": [
    "kubernetes",
    "k8s",
    "cost",
    "finops",
    "eks",
    "gke",
    "aks",
    "hetzner",
    "devops",
    "github-actions"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "podmonkey": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "pricing",
    "README.md",
    "LICENSE"
  ],
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && esbuild src/cli/index.ts --bundle --platform=node --packages=external --format=esm --outfile=dist/cli/index.js --banner:js='#!/usr/bin/env node'",
    "prepublishOnly": "npm run build",
    "podmonkey": "npm run build && node dist/cli/index.js",
    "refresh-pricing": "tsx src/pricing/refresh/run.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "cron-parser": "^5.0.6",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
