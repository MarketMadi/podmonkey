{
  "name": "podmonkey",
  "version": "0.1.0",
  "private": true,
  "description": "Paste Kubernetes YAML. Compare cloud bills.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "podmonkey": "./dist/cli/index.js"
  },
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && esbuild src/cli/index.ts --bundle --platform=node --packages=external --format=esm --outfile=dist/cli/index.js --banner:js='#!/usr/bin/env node'",
    "podmonkey": "npm run build && node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
